{
  "name": "gws-connect",
  "private": true,
  "version": "1.0.0",
  "description": "GWS Connect desktop shell and web workspace",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "db:inspect:local": "bash scripts/db/inspect-local.sh",
    "db:backup:local": "bash scripts/db/backup-local.sh",
    "db:promote:prod": "bash scripts/db/promote-to-production.sh",
    "db:sync:dev-to-prod": "bash scripts/db/sync-dev-to-prod.sh",
    "db:remote-only-deploy": "bash scripts/db/remote-only-deploy.sh",
    "db:upload-and-remote-deploy": "bash scripts/db/upload-and-remote-deploy.sh",
    "electron:dev": "node electron/dev-launcher.cjs",
    "dev:electron": "concurrently -k \"npm run dev --prefix server\" \"npm run dev --prefix client\" \"npm run electron:dev\"",
    "build:desktop": "npm run build:desktop --prefix client",
    "dist:mac": "npm run build:desktop && electron-builder --mac",
    "dist:win": "npm run build:desktop && electron-builder --win",
    "dist:linux": "npm run build:desktop && electron-builder --linux"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "net.gwsapp.connect",
    "productName": "GWS Connect",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "client/dist",
        "to": "client/dist"
      },
      {
        "from": "server",
        "to": "server",
        "filter": [
          "package.json",
          ".env",
          "src/**/*",
          "node_modules/**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.social-networking"
    },
    "asar": true
  }
}
