PORT=3001
# Required in production (server refuses to start without it there).
# In docker-compose.yml this is set explicitly to /app/data/gws-connect.db
# to match the server volume mount - do not rely on this .env file alone
# in production, since it is not tracked and can be recreated without it.
DB_PATH=./data/gws-connect.db
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
CLIENT_URL=http://localhost:5173
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@gwsapp.net
MAX_FILE_SIZE_MB=250
SENDGRID_API_KEY=
EMAIL_FROM=connect@gwsapp.net
EMAIL_REPLY_TO=grant@gwsapp.net
PRODUCTION_SYNC_URL=
DATA_SYNC_SHARED_SECRET=
# LiveKit Cloud project (livekit.io) - calls are disabled until all three are set.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
